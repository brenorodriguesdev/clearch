{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "emitDeclarationOnly": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true
  },
  "include": ["src/index.ts", "src/lib/**/*.ts"],
  "exclude": ["src/**/*.spec.ts"]
}
